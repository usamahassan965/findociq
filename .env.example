# --- Vector store ---
QDRANT_URL=http://localhost:6333
# For Qdrant Cloud free tier, set both:
# QDRANT_URL=https://xxxx.cloud.qdrant.io
# QDRANT_API_KEY=your-key

# --- Generation provider: gemini (free tier) | ollama (free, local) | anthropic (paid) ---
VLM_PROVIDER=gemini

# Free API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Local Ollama (run: ollama pull qwen2.5vl:7b)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:7b

# Optional paid provider (highest quality)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Embedding models ---
VISUAL_MODEL=vidore/colqwen2.5-v0.2
TEXT_MODEL=BAAI/bge-small-en-v1.5

# --- Retrieval ---
TOP_K=5
